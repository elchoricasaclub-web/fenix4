rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Role-Based Access Control Example for FENIX1
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Admins or specific roles
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Users collection: users can read/write their own profile
    match /users/{userId} {
      allow read: if isOwner(userId) || hasRole('ADMIN');
      allow write: if isOwner(userId) || hasRole('ADMIN');
    }

    // Batches collection:
    match /batches/{batchId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('ADMIN') || hasRole('AGROMANAGER');
    }
    
    // Audits collection:
    match /audits/{auditId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('ADMIN') || hasRole('AUDITOR');
    }
    
    // Inventory collection:
    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('ADMIN') || hasRole('INVENTORY_MANAGER');
    }
  }
}
